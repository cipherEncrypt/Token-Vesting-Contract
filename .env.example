# Sepolia RPC endpoint (use your own — never commit real keys)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Deployer wallet (must hold Sepolia ETH) — keep in project-root .env only
PRIVATE_KEY=0x...

# Vesting parameters
BENEFICIARY=0x...
VESTING_START=1700000000
CLIFF_DURATION=7776000
VESTING_DURATION=31536000
MINT_AMOUNT=1000000000000000000000000

# true = deploy MockERC20 and fund the wallet; false = use existing token
DEPLOY_MOCK_TOKEN=true
TOKEN_ADDRESS=0x...

# Optional — for --verify
ETHERSCAN_API_KEY=
